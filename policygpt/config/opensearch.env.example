# OpenSearch credentials — copy this file to opensearch.env and fill in real values.
# opensearch.env is gitignored and must never be committed.

OS_HOST=localhost
OS_PORT=9200
OS_USERNAME=admin
OS_PASSWORD=
OS_USE_SSL=true
OS_VERIFY_CERTS=false
OS_INDEX_PREFIX=policygpt

# Comma-separated list of user IDs granted access to all ingested documents.
# Must match the user_id values sent in the browser cookie.
# Example: POLICY_GPT_INGESTION_USER_IDS=alice,bob,carol
POLICY_GPT_INGESTION_USER_IDS=
